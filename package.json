{
  "name": "rigrunner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A vehicle-building scavenger game. Build a modular rig, run it across a hostile landscape, re-fit, repeat.",
  "scripts": {
    "dev:game": "vite game",
    "build:game": "vite build game",
    "typecheck:game": "tsc --noEmit -p game/tsconfig.json",
    "test:game": "vitest run game",
    "test:game:watch": "vitest game",
    "dev:viewer": "vite viewer",
    "build:viewer": "vite build viewer",
    "typecheck:viewer": "tsc --noEmit -p viewer/tsconfig.json"
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
